{
  "manifest_version": 2,
  "name": "yt-dlp Downloader",
  "version": "0.6",
  "description": "Download YouTube videos using yt-dlp",
  "permissions": [
    "nativeMessaging",
    "activeTab"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "yt-dlp-dl@wakefield.fyi",
      "strict_min_version": "55.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": ["none"],
        "disclosure": {
          "en": "This extension does not collect or transmit any personal data. It sends only the YouTube video URL and your selected format to a locally installed native application (yt-dlp) on your computer."
        }
      }
    }
  },
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ]
}
